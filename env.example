# RTL Converter — 환경 설정 파일
# 이 파일을 .env로 복사하고 값을 채워넣으세요
# cp .env.example .env

# ── LLM 서버 설정 ──────────────────────────────────────────
# OpenAI Compatible 서버 Base URL
# 예) 사내 서버:  http://192.168.10.50:8000/v1
# 예) OpenAI:    https://api.openai.com/v1
BASE_URL=http://your-llm-server/v1

# API Key (없으면 빈칸)
API_KEY=

# 기본 모델명 (연결 테스트 후 드롭다운에서 자동 선택됨)
DEFAULT_MODEL=your-model-name

# ── 개발/테스트 전용 ────────────────────────────────────────
# Ollama로 로컬 테스트 시에만 true로 설정
# true로 설정하면 num_ctx 파라미터가 활성화되고
# 파라미터 팝업에 Ollama 전용 항목이 표시됩니다
# 운영 환경에서는 반드시 false 또는 제거하세요
OLLAMA_MODE=false

# Ollama 사용 예시:
# BASE_URL=http://localhost:11434/v1
# DEFAULT_MODEL=llama3.3
# OLLAMA_MODE=true

# ── Lint 도구 설정 (선택) ───────────────────────────────────
# SystemC 헤더 경로 (clang++ -I 옵션으로 전달)
# 콜론 구분으로 다중 경로 지정 가능
# 미설정 시 기본값: /usr/include/systemc
#
# 예) Debian/Ubuntu 표준 패키지: /usr/include/systemc
# 예) 사내 빌드 컨테이너:        /opt/systemc/include
# 예) 다중 경로:                 /opt/systemc/include:/usr/local/include/tlm
# SYSTEMC_INCLUDE=/usr/include/systemc

# ── 아웃바운드 프록시 (선택) ────────────────────────────────
# LLM 서버로 가는 요청에 사용할 명시적 프록시.
# 사내 인트라넷 LLM 서버는 보통 프록시 경유 불필요 — 그대로 비워두세요.
#
# 시스템 프록시 / HTTP_PROXY 환경변수는 자동으로 적용되지 않습니다.
# (인트라넷 서버 요청이 외부망 프록시로 잘못 우회되어 407 발생하는 회귀 방지)
#
# 정말로 프록시 경유가 필요한 환경에서만 아래에 명시:
# OUTBOUND_PROXY=http://proxy.company.com:8080
# OUTBOUND_PROXY=http://user:pass@proxy.company.com:8080
